PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173
PLAYWRIGHT_SKIP_WEB_SERVER=false
# Set to true to run tests that insert into Supabase (membership RPC, forms, etc.)
E2E_ENABLE_FORM_SUBMISSIONS=false
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# Optional: general member account for /profile E2E (same shared /login as admins)
E2E_MEMBER_EMAIL=
E2E_MEMBER_PASSWORD=
# Set true to run tiny file upload smoke tests (requires working Storage + RLS in env)
E2E_ENABLE_UPLOAD_TESTS=false
E2E_FORCE_PASSWORD_EMAIL=
E2E_FORCE_PASSWORD_PASSWORD=
E2E_FORCE_PASSWORD_NEW_PASSWORD=
