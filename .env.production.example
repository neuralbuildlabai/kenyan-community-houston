# ============================================================
# .env.production.example — Kenyan Community Houston (KIGH)
# ============================================================
# This is a template. Copy values from your secret manager into the
# production environment (Vercel project env vars / 1Password etc.).
# NEVER COMMIT REAL PRODUCTION SECRETS to this repo.

# Required: declare this build as production. The frontend uses this
# to suppress the staging banner and to enforce the Supabase URL
# allow-list guard in src/lib/supabase.ts (it will refuse to boot
# if VITE_SUPABASE_URL is not in VITE_PRODUCTION_SUPABASE_URLS).
VITE_APP_ENV=production

# Supabase production project (kch-production)
VITE_SUPABASE_URL=https://your-production-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-key-here

# Allow-lists used by the runtime guard.
VITE_PRODUCTION_SUPABASE_URLS=https://your-production-ref.supabase.co
VITE_STAGING_SUPABASE_URLS=https://your-staging-ref.supabase.co

# App
VITE_APP_URL=https://kenyancommunityhouston.org
VITE_APP_NAME=Kenyan Community Houston
VITE_SITE_NAME=Kenyan Community Houston
VITE_CONTACT_EMAIL=info@kenyancommunityhouston.org
