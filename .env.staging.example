# ============================================================
# .env.staging.example — Kenyan Community Houston (KIGH)
# ============================================================
# This is a template. Copy values from your secret manager (Vercel
# project env vars / 1Password / etc.) into the staging environment.
# Never commit real secrets.

# Required: declare this build as staging/UAT. The frontend uses this
# to render a top-of-page warning banner and to enforce the Supabase
# URL allow-list guard in src/lib/supabase.ts.
VITE_APP_ENV=staging

# Supabase staging project (kch-staging)
VITE_SUPABASE_URL=https://your-staging-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key-here

# Allow-lists used by the runtime guard.
# VITE_PRODUCTION_SUPABASE_URLS should contain ONLY production URLs.
# VITE_STAGING_SUPABASE_URLS should contain the staging URL above.
VITE_PRODUCTION_SUPABASE_URLS=https://your-production-ref.supabase.co
VITE_STAGING_SUPABASE_URLS=https://your-staging-ref.supabase.co

# App
VITE_APP_URL=https://staging.kenyancommunityhouston.org
VITE_APP_NAME=Kenyan Community Houston (Staging)
VITE_SITE_NAME=Kenyan Community Houston
VITE_CONTACT_EMAIL=staging@kenyancommunityhouston.org
