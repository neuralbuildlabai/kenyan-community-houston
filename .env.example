# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App env: production | staging | development
# Treat the current Supabase project as STAGING/UAT until a clean
# production project is provisioned. Defaults to "development" when
# unset.
VITE_APP_ENV=development

# Optional defence-in-depth allow-lists. Comma-separated Supabase URLs.
# When set, the app refuses to boot in production if VITE_SUPABASE_URL
# is not in VITE_PRODUCTION_SUPABASE_URLS, and warns loudly in staging
# if VITE_SUPABASE_URL is not in VITE_STAGING_SUPABASE_URLS.
VITE_PRODUCTION_SUPABASE_URLS=
VITE_STAGING_SUPABASE_URLS=

# App
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Kenyan Community Houston
VITE_SITE_NAME=Kenyan Community Houston
VITE_CONTACT_EMAIL=info@kenyancommunityhouston.org
